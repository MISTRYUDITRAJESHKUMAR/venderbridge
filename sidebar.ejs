<%- include('partials/head', { title: 'Dashboard' }) %>

<div class="app-container">
  <%- include('partials/sidebar') %>

  <main class="main-wrapper">
    <!-- Top Bar -->
    <div class="top-bar">
      <div class="page-title">
        <h1>Welcome Back, <%= user.name %></h1>
        <p>Here is an overview of the procurement activities today.</p>
      </div>
    </div>

    <!-- Quick Action Toolbar Buttons -->
    <div class="panel no-print" style="padding: 1rem 1.5rem; display: flex; flex-direction: row; align-items: center; gap: 1rem; flex-wrap: wrap;">
      <span style="font-size: 0.8rem; font-weight: 700; color: var(--color-primary); text-transform: uppercase; letter-spacing: 0.05em; margin-right: 0.5rem; display: flex; align-items: center; gap: 0.25rem;">
        <i data-lucide="zap" style="width: 14px; height: 14px;"></i>
        <span>Quick Actions:</span>
      </span>
      <% if (user.role === 'PROCUREMENT_OFFICER') { %>
        <a href="/rfqs/create" class="btn btn-primary btn-sm">
          <i data-lucide="plus-circle" style="width: 14px; height: 14px;"></i>
          <span>Create RFQ</span>
        </a>
        <a href="/vendors" class="btn btn-secondary btn-sm">
          <i data-lucide="user-plus" style="width: 14px; height: 14px;"></i>
          <span>Manage Vendors</span>
        </a>
        <a href="/approvals" class="btn btn-secondary btn-sm">
          <i data-lucide="shield-alert" style="width: 14px; height: 14px;"></i>
          <span>Check Approvals</span>
        </a>
      <% } else if (user.role === 'VENDOR') { %>
        <a href="/rfqs" class="btn btn-primary btn-sm">
          <i data-lucide="file-spreadsheet" style="width: 14px; height: 14px;"></i>
          <span>Submit Bid / Quotation</span>
        </a>
        <a href="/pos" class="btn btn-secondary btn-sm">
          <i data-lucide="receipt" style="width: 14px; height: 14px;"></i>
          <span>Generate Invoice</span>
        </a>
      <% } else if (user.role === 'APPROVER') { %>
        <a href="/approvals" class="btn btn-primary btn-sm">
          <i data-lucide="shield-check" style="width: 14px; height: 14px;"></i>
          <span>Review Approvals</span>
        </a>
        <a href="/reports" class="btn btn-secondary btn-sm">
          <i data-lucide="bar-chart-3" style="width: 14px; height: 14px;"></i>
          <span>Financial Reports</span>
        </a>
      <% } else if (user.role === 'ADMIN') { %>
        <a href="/vendors" class="btn btn-primary btn-sm">
          <i data-lucide="users" style="width: 14px; height: 14px;"></i>
          <span>Manage Vendors</span>
        </a>
        <a href="/logs" class="btn btn-secondary btn-sm">
          <i data-lucide="history" style="width: 14px; height: 14px;"></i>
          <span>Audit Log Trail</span>
        </a>
      <% } %>
    </div>

    <!-- Metrics Cards Grid -->
    <div class="metrics-grid">
      <% if (user.role === 'VENDOR') { %>
        <div class="metric-card">
          <div class="metric-icon primary">
            <i data-lucide="file-text"></i>
          </div>
          <div class="metric-info">
            <span class="metric-value"><%= stats.activeRfqs %></span>
            <span class="metric-label">Active Assigned RFQs</span>
          </div>
        </div>

        <div class="metric-card">
          <div class="metric-icon info">
            <i data-lucide="send"></i>
          </div>
          <div class="metric-info">
            <span class="metric-value"><%= stats.submittedQuotes %></span>
            <span class="metric-label">Submitted Quotes</span>
          </div>
        </div>

        <div class="metric-card">
          <div class="metric-icon success">
            <i data-lucide="shopping-bag"></i>
          </div>
          <div class="metric-info">
            <span class="metric-value"><%= stats.totalPOs %></span>
            <span class="metric-label">Purchase Orders</span>
          </div>
        </div>

        <div class="metric-card">
          <div class="metric-icon warning">
            <i data-lucide="receipt"></i>
          </div>
          <div class="metric-info">
            <span class="metric-value"><%= stats.totalInvoices %></span>
            <span class="metric-label">Invoices Issued</span>
          </div>
        </div>
      <% } else { %>
        <div class="metric-card">
          <div class="metric-icon primary">
            <i data-lucide="file-text"></i>
          </div>
          <div class="metric-info">
            <span class="metric-value"><%= stats.activeRfqs %></span>
            <span class="metric-label">Active RFQs</span>
          </div>
        </div>

        <div class="metric-card">
          <div class="metric-icon warning">
            <i data-lucide="clock"></i>
          </div>
          <div class="metric-info">
            <span class="metric-value"><%= stats.pendingApprovals %></span>
            <span class="metric-label">Pending Approvals</span>
          </div>
        </div>

        <div class="metric-card">
          <div class="metric-icon success">
            <i data-lucide="shopping-bag"></i>
          </div>
          <div class="metric-info">
            <span class="metric-value"><%= stats.totalPOs %></span>
            <span class="metric-label">Purchase Orders</span>
          </div>
        </div>

        <div class="metric-card">
          <div class="metric-icon info">
            <i data-lucide="receipt"></i>
          </div>
          <div class="metric-info">
            <span class="metric-value"><%= stats.totalInvoices %></span>
            <span class="metric-label">Invoices Generated</span>
          </div>
        </div>
      <% } %>
    </div>

    <!-- Analytics Dashboard Panels -->
    <% if (user.role !== 'VENDOR') { %>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 1.5rem;" class="no-print">
        <div class="panel">
          <div class="panel-header">
            <h3 class="panel-title">Procurement Spend Summary</h3>
            <span style="font-size: 0.8rem; color: var(--text-muted);">Last 6 Months (INR)</span>
          </div>
          <div style="height: 250px; position: relative;">
            <canvas id="spendingChart"></canvas>
          </div>
        </div>

        <div class="panel">
          <div class="panel-header">
            <h3 class="panel-title">Top Rated Vendors</h3>
            <span style="font-size: 0.8rem; color: var(--text-muted);">Rating Scores</span>
          </div>
          <div style="height: 250px; position: relative;">
            <canvas id="ratingChart"></canvas>
          </div>
        </div>
      </div>
    <% } %>

    <!-- Recent Items Lists -->
    <div class="dashboard-grid">
      <!-- Panel 1: Recent POs -->
      <div class="panel">
        <div class="panel-header">
          <h3 class="panel-title">Recent Purchase Orders</h3>
          <a href="/pos" class="btn btn-secondary btn-sm no-print">View All</a>
        </div>
        <div class="table-responsive">
          <table class="data-table">
            <thead>
              <tr>
                <th>PO Number</th>
                <th>Vendor</th>
                <th>Total Value</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% if (recentPOs.length === 0) { %>
                <tr>
                  <td colspan="4" style="text-align: center; color: var(--text-muted); padding: 2rem;">No purchase orders found.</td>
                </tr>
              <% } else { %>
                <% recentPOs.forEach(po => { %>
                  <tr>
                    <td><strong><%= po.po_number %></strong></td>
                    <td><%= po.vendor_name %></td>
                    <td>₹<%= po.grand_total.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
                    <td>
                      <span class="badge <%= po.status.toLowerCase() %>"><%= po.status %></span>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Panel 2: Activity Logs -->
      <div class="panel">
        <div class="panel-header">
          <h3 class="panel-title">Recent Activities</h3>
          <% if (user.role !== 'VENDOR') { %>
            <a href="/logs" class="btn btn-secondary btn-sm no-print">All Trails</a>
          <% } %>
        </div>
        <div class="timeline">
          <% if (logs.length === 0) { %>
            <p style="text-align: center; color: var(--text-muted); padding: 2rem; font-size: 0.9rem;">No recent activities logged.</p>
          <% } else { %>
            <% logs.forEach((log, index) => { %>
              <div class="timeline-item <%= index === 0 ? 'active' : '' %>">
                <div class="timeline-marker">
                  <i data-lucide="activity" style="width: 14px; height: 14px;"></i>
                </div>
                <div class="timeline-content">
                  <span class="timeline-title"><%= log.action %></span>
                  <span class="timeline-desc"><%= log.details %></span>
                  <span class="timeline-time">by <%= log.user_name %> &bull; <%= new Date(log.timestamp).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></span>
                </div>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>
  </main>
</div>

<!-- Load Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  // Dynamic Charting Configuration
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Spending Chart Setup
    const spendingCanvas = document.getElementById('spendingChart');
    if (spendingCanvas) {
      const rawSpending = <%- monthlySpendingData %>;
      const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
      
      // Map numbers to month names
      const labels = rawSpending.map(d => months[parseInt(d.month_num) - 1]);
      const data = rawSpending.map(d => d.total);

      new Chart(spendingCanvas, {
        type: 'line',
        data: {
          labels: labels.length ? labels : ['Current Month'],
          datasets: [{
            label: 'Total Spends (INR)',
            data: data.length ? data : [0],
            borderColor: '#6366f1',
            backgroundColor: 'rgba(99, 102, 241, 0.15)',
            fill: true,
            tension: 0.35,
            borderWidth: 3,
            pointRadius: 4,
            pointBackgroundColor: '#6366f1'
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false }
          },
          scales: {
            x: {
              grid: { display: false },
              ticks: { color: '#94a3b8', font: { family: 'Inter' } }
            },
            y: {
              grid: { color: 'rgba(255, 255, 255, 0.05)' },
              ticks: { color: '#94a3b8', font: { family: 'Inter' } }
            }
          }
        }
      });
    }

    // 2. Vendor Ratings Chart Setup
    const ratingCanvas = document.getElementById('ratingChart');
    if (ratingCanvas) {
      const rawRatings = <%- topVendorsData %>;
      const labels = rawRatings.map(v => v.name);
      const data = rawRatings.map(v => v.rating);

      new Chart(ratingCanvas, {
        type: 'bar',
        data: {
          labels: labels,
          datasets: [{
            label: 'Rating Score',
            data: data,
            backgroundColor: 'rgba(16, 185, 129, 0.85)',
            hoverBackgroundColor: '#10b981',
            borderRadius: 6,
            borderWidth: 0
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false }
          },
          scales: {
            x: {
              grid: { display: false },
              ticks: { color: '#94a3b8', font: { family: 'Inter' } }
            },
            y: {
              grid: { color: 'rgba(255, 255, 255, 0.05)' },
              ticks: { color: '#94a3b8', font: { family: 'Inter' } },
              max: 5,
              min: 0
            }
          }
        }
      });
    }
  });
</script>

<%- include('partials/footer') %>
