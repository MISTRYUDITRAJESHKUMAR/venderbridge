<%- include('partials/head', { title: 'Activity Trail' }) %>

<div class="app-container">
  <%- include('partials/sidebar') %>

  <main class="main-wrapper">
    <!-- Top Header -->
    <div class="top-bar">
      <div class="page-title">
        <h1>System Audit Trail</h1>
        <p>Comprehensive, immutable log records mapping all state transitions, user access, and system activities.</p>
      </div>
    </div>

    <!-- Logs Panel -->
    <div class="panel">
      <div class="panel-header">
        <h3 class="panel-title">System Activity Logs</h3>
        <span style="font-size: 0.8rem; color: var(--text-muted);">Showing last 100 entries</span>
      </div>
      
      <div class="table-responsive">
        <table class="data-table">
          <thead>
            <tr>
              <th style="width: 15%;">Timestamp</th>
              <th style="width: 20%;">Actor Name</th>
              <th style="width: 20%;">Action Event</th>
              <th style="width: 45%;">Operation Details</th>
            </tr>
          </thead>
          <tbody>
            <% if (logs.length === 0) { %>
              <tr>
                <td colspan="4" style="text-align: center; color: var(--text-muted); padding: 3rem;">No activity logs recorded.</td>
              </tr>
            <% } else { %>
              <% logs.forEach(log => { %>
                <tr>
                  <td>
                    <span style="font-size: 0.8rem; color: var(--text-muted);">
                      <%= new Date(log.timestamp).toLocaleString([], { dateStyle: 'short', timeStyle: 'short' }) %>
                    </span>
                  </td>
                  <td>
                    <div style="display: flex; align-items: center; gap: 0.35rem;">
                      <i data-lucide="user" style="width: 14px; height: 14px; color: var(--color-primary);"></i>
                      <strong><%= log.user_name %></strong>
                    </div>
                  </td>
                  <td>
                    <span class="badge" style="background: rgba(255, 255, 255, 0.05); color: var(--text-main); border: 1px solid var(--border-light);">
                      <%= log.action %>
                    </span>
                  </td>
                  <td style="color: var(--text-muted); font-size: 0.85rem;"><%= log.details %></td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<%- include('partials/footer') %>
