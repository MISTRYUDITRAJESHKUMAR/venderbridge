<%- include('partials/head', { title: 'Procurement Approvals' }) %>

<div class="app-container">
  <%- include('partials/sidebar') %>

  <main class="main-wrapper">
    <!-- Top Header -->
    <div class="top-bar">
      <div class="page-title">
        <h1>Procurement Approvals Workflow</h1>
        <p>
          <% if (user.role === 'APPROVER') { %>
            Review requested quotes, inspect specifications, and approve or reject procurement requests.
          <% } else { %>
            Monitor status of quotation approval requests submitted to managers.
          <% } %>
        </p>
      </div>
    </div>

    <!-- Section: Pending Reviews -->
    <div class="panel">
      <div class="panel-header">
        <h3 class="panel-title">Pending Approvals (<%= pendingApprovals.length %>)</h3>
      </div>

      <% if (pendingApprovals.length === 0) { %>
        <div style="text-align: center; padding: 4rem; color: var(--text-muted);">
          <div style="margin-bottom: 1rem;"><i data-lucide="shield-check" style="width: 48px; height: 48px; color: var(--color-success); opacity: 0.6;"></i></div>
          <h3>All Caught Up!</h3>
          <p style="font-size: 0.9rem; margin-top: 0.25rem;">There are no procurement requests waiting for approval review.</p>
        </div>
      <% } else { %>
        <div style="display: flex; flex-direction: column; gap: 1.5rem; margin-top: 1rem;">
          <% pendingApprovals.forEach(quote => { %>
            <div style="border: 1px solid var(--border-light); border-radius: var(--radius-md); background: rgba(255,255,255,0.01); padding: 1.5rem;">
              
              <!-- Quote Header Info -->
              <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem; border-bottom: 1px dashed var(--border-light); padding-bottom: 1rem;">
                <div>
                  <span style="font-size: 0.75rem; text-transform: uppercase; color: var(--color-primary); font-weight: 600; letter-spacing: 0.05em;">Request for:</span>
                  <h4 style="font-size: 1.15rem; font-family: 'Outfit'; color: var(--text-main); margin-top: 0.15rem;"><%= quote.rfq_title %></h4>
                  <p style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.15rem;">Submitted by: <strong><%= quote.vendor_name %></strong> (Rating: <%= quote.vendor_rating.toFixed(1) %> ★)</p>
                </div>

                <div style="text-align: right;">
                  <span style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase;">Quoted Value</span>
                  <div style="font-size: 1.5rem; font-weight: 700; color: var(--text-main); font-family: 'Outfit';">
                    ₹<%= quote.totalValue.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %>
                  </div>
                  <span style="font-size: 0.8rem; color: var(--text-muted);">Delivery Timeline: <strong><%= quote.delivery_timeline_days %> Days</strong></span>
                </div>
              </div>

              <!-- Collapsible Items inside card -->
              <div style="margin: 1rem 0;">
                <button onclick="toggleApprovalItems('<%= quote.id %>')" class="btn btn-secondary btn-sm" style="border: none; background: none; padding: 0; display: inline-flex; align-items: center; gap: 0.35rem; color: var(--color-info); cursor: pointer;">
                  <i data-lucide="chevron-down" id="app-arrow-<%= quote.id %>" style="width: 14px; height: 14px; transition: var(--transition-smooth);"></i>
                  <span id="app-label-<%= quote.id %>">Review Item Pricing Details (<%= quote.items.length %>)</span>
                </button>

                <div id="app-items-<%= quote.id %>" style="display: none; margin-top: 0.75rem;">
                  <div class="table-responsive" style="border: 1px solid var(--border-light); border-radius: var(--radius-sm); background: rgba(0,0,0,0.15);">
                    <table class="data-table" style="font-size: 0.85rem;">
                      <thead>
                        <tr>
                          <th>Item Name</th>
                          <th>Quantity</th>
                          <th>Unit Price</th>
                          <th style="text-align: right;">Line Total</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% quote.items.forEach(item => { %>
                          <tr>
                            <td><%= item.itemId %></td>
                            <td><%= item.totalPrice / item.pricePerUnit %></td>
                            <td>₹<%= item.pricePerUnit.toFixed(2) %></td>
                            <td style="text-align: right; font-weight: 600; font-family: monospace;">₹<%= item.totalPrice.toFixed(2) %></td>
                          </tr>
                        <% }) %>
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>

              <% if (quote.notes && quote.notes.trim() !== '') { %>
                <div style="font-size: 0.85rem; color: var(--text-muted); background: rgba(255,255,255,0.02); padding: 0.5rem 0.75rem; border-radius: var(--radius-sm); margin-bottom: 1rem; border-left: 3px solid var(--border-light);">
                  <strong>Vendor Remarks:</strong> "<%= quote.notes %>"
                </div>
              <% } %>

              <!-- Action form (Only visible to Managers/Approvers) -->
              <% if (user.role === 'APPROVER') { %>
                <form action="/approvals/action" method="POST" style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--border-light);">
                  <input type="hidden" name="quoteId" value="<%= quote.id %>">
                  <div style="display: flex; gap: 1rem; align-items: flex-end; flex-wrap: wrap;">
                    <div class="form-group" style="flex-grow: 1; margin-bottom: 0;">
                      <label for="remarks-<%= quote.id %>" style="font-size: 0.75rem;">Approval / Rejection Remarks</label>
                      <input type="text" id="remarks-<%= quote.id %>" name="remarks" class="form-control" placeholder="Provide reason/remarks for approval or rejection..." required>
                    </div>

                    <div style="display: flex; gap: 0.5rem; flex-shrink: 0;">
                      <button type="submit" name="action" value="REJECT" class="btn btn-danger" style="height: 42px;">
                        <i data-lucide="x-circle"></i>
                        <span>Reject Request</span>
                      </button>
                      <button type="submit" name="action" value="APPROVE" class="btn btn-success" style="height: 42px;">
                        <i data-lucide="check-circle2"></i>
                        <span>Approve & Issue PO</span>
                      </button>
                    </div>
                  </div>
                </form>
              <% } else { %>
                <div style="margin-top: 1rem; padding-top: 0.5rem; border-top: 1px solid var(--border-light); font-size: 0.8rem; color: var(--text-muted); display: flex; align-items: center; gap: 0.25rem;">
                  <i data-lucide="info" style="width: 14px; height: 14px; color: var(--color-warning);"></i>
                  <span>Submitted for review. Awaiting manager action to approve or reject.</span>
                </div>
              <% } %>

            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Section: Decision History -->
    <div class="panel">
      <div class="panel-header">
        <h3 class="panel-title">Decision History</h3>
      </div>
      <div class="table-responsive">
        <table class="data-table">
          <thead>
            <tr>
              <th>RFQ / Subject</th>
              <th>Vendor</th>
              <th>Total Bid</th>
              <th>Status</th>
              <th>Approver / Signer</th>
              <th>Remarks / Date</th>
            </tr>
          </thead>
          <tbody>
            <% if (approvalHistory.length === 0) { %>
              <tr>
                <td colspan="6" style="text-align: center; color: var(--text-muted); padding: 2rem;">No decision history registered yet.</td>
              </tr>
            <% } else { %>
              <% approvalHistory.forEach(history => { %>
                <tr>
                  <td>
                    <div style="display: flex; flex-direction: column;">
                      <strong><%= history.rfq_title %></strong>
                      <span style="font-size: 0.75rem; color: var(--text-muted);">Quote ID: <%= history.id %></span>
                    </div>
                  </td>
                  <td><%= history.vendor_name %></td>
                  <td><strong style="font-family: monospace;">₹<%= history.totalValue.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></strong></td>
                  <td>
                    <span class="badge <%= history.status.toLowerCase() %>"><%= history.status %></span>
                  </td>
                  <td><%= history.approver_name || 'System Auto' %></td>
                  <td>
                    <div style="display: flex; flex-direction: column;">
                      <span style="font-size: 0.85rem; color: var(--text-main);">"<%= history.approval_remarks || 'N/A' %>"</span>
                      <span style="font-size: 0.75rem; color: var(--text-muted);"><%= new Date(history.submitted_at).toLocaleDateString() %></span>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<script>
  function toggleApprovalItems(quoteId) {
    const section = document.getElementById('app-items-' + quoteId);
    const arrow = document.getElementById('app-arrow-' + quoteId);
    const label = document.getElementById('app-label-' + quoteId);
    const qty = section.querySelectorAll('tbody tr').length;

    if (section.style.display === 'none') {
      section.style.display = 'block';
      arrow.style.transform = 'rotate(180deg)';
      label.innerText = 'Hide Item Pricing Details (' + qty + ')';
    } else {
      section.style.display = 'none';
      arrow.style.transform = 'rotate(0deg)';
      label.innerText = 'Review Item Pricing Details (' + qty + ')';
    }
  }
</script>

<%- include('partials/footer') %>
