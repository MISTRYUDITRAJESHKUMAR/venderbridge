<div class="sidebar no-print">
  <div class="brand">
    <div class="brand-logo">VB</div>
    <span class="brand-name">VendorBridge</span>
  </div>

  <% if (user) { %>
    <div class="user-profile">
      <span class="user-name"><%= user.name %></span>
      <span class="user-role"><%= user.role.replace('_', ' ') %></span>
    </div>
  <% } %>

  <ul class="nav-menu">
    <li class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">
      <a href="/dashboard">
        <i data-lucide="layout-dashboard"></i>
        <span>Dashboard</span>
      </a>
    </li>

    <% if (user) { %>
      <!-- ADMIN, PROCUREMENT_OFFICER, APPROVER can view Vendors -->
      <% if (['ADMIN', 'PROCUREMENT_OFFICER'].includes(user.role)) { %>
        <li class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'vendors' ? 'active' : '' %>">
          <a href="/vendors">
            <i data-lucide="users"></i>
            <span>Vendor Directory</span>
          </a>
        </li>
      <% } %>

      <!-- RFQs: VENDORs see assigned RFQs, PROCUREMENT_OFFICERs create & manage -->
      <% if (['PROCUREMENT_OFFICER', 'VENDOR'].includes(user.role)) { %>
        <li class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'rfqs' ? 'active' : '' %>">
          <a href="/rfqs">
            <i data-lucide="file-text"></i>
            <span>RFQs</span>
          </a>
        </li>
      <% } %>

      <!-- Approvals: APPROVERs and PROCUREMENT_OFFICERs can view/action them -->
      <% if (['APPROVER', 'PROCUREMENT_OFFICER'].includes(user.role)) { %>
        <li class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'approvals' ? 'active' : '' %>">
          <a href="/approvals">
            <i data-lucide="shield-check"></i>
            <span>Approvals</span>
          </a>
        </li>
      <% } %>

      <!-- Purchase Orders & Invoices: VENDORs (own), OFFICERS, APPROVERs -->
      <% if (['PROCUREMENT_OFFICER', 'VENDOR', 'APPROVER'].includes(user.role)) { %>
        <li class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'pos' ? 'active' : '' %>">
          <a href="/pos">
            <i data-lucide="receipt"></i>
            <span>POs & Invoices</span>
          </a>
        </li>
      <% } %>

      <!-- Mock Email Log: View simulated emails -->
      <% if (['PROCUREMENT_OFFICER', 'VENDOR'].includes(user.role)) { %>
        <li class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'emails' ? 'active' : '' %>">
          <a href="/emails">
            <i data-lucide="mail"></i>
            <span>Email Outbox</span>
          </a>
        </li>
      <% } %>

      <!-- Reports & Analytics: ADMIN, PROCUREMENT_OFFICER, APPROVER -->
      <% if (['ADMIN', 'PROCUREMENT_OFFICER', 'APPROVER'].includes(user.role)) { %>
        <li class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'reports' ? 'active' : '' %>">
          <a href="/reports">
            <i data-lucide="bar-chart-3"></i>
            <span>Reports & Analytics</span>
          </a>
        </li>
      <% } %>

      <!-- Activity Logs (Auditing): ADMIN, PROCUREMENT_OFFICER, APPROVER -->
      <% if (['ADMIN', 'PROCUREMENT_OFFICER', 'APPROVER'].includes(user.role)) { %>
        <li class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'logs' ? 'active' : '' %>">
          <a href="/logs">
            <i data-lucide="history"></i>
            <span>Activity Trail</span>
          </a>
        </li>
      <% } %>
    <% } %>
  </ul>

  <% if (user) { %>
    <div class="logout-btn">
      <a href="/logout" class="btn btn-secondary btn-sm" style="width: 100%; display: flex;">
        <i data-lucide="log-out" style="width: 16px; height: 16px;"></i>
        <span>Sign Out</span>
      </a>
    </div>
  <% } %>
</div>
