<%- include('partials/head', { title: 'Error' }) %>

<div class="app-container">
  <%- include('partials/sidebar') %>

  <main class="main-wrapper">
    <div class="panel" style="max-width: 600px; margin: 4rem auto; text-align: center; display: flex; flex-direction: column; align-items: center; padding: 3rem;">
      <div style="background: rgba(239, 68, 68, 0.1); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem;">
        <i data-lucide="alert-triangle" style="width: 48px; height: 48px; color: var(--color-danger);"></i>
      </div>
      
      <h2 style="font-size: 1.75rem; margin-bottom: 0.5rem; font-family: 'Outfit';">System Error</h2>
      <p style="color: var(--text-muted); margin-bottom: 2rem;"><%= typeof message !== 'undefined' ? message : 'An unexpected server error occurred.' %></p>
      
      <div style="display: flex; gap: 1rem;">
        <a href="/dashboard" class="btn btn-primary">
          <i data-lucide="home"></i>
          <span>Return Home</span>
        </a>
        <button onclick="window.history.back()" class="btn btn-secondary">
          <i data-lucide="arrow-left"></i>
          <span>Go Back</span>
        </button>
      </div>
    </div>
  </main>
</div>

<%- include('partials/footer') %>
