<%- include('partials/head', { title: 'Sign In' }) %>

<div class="login-container">
  <div class="login-card">
    <div class="login-header">
      <div class="login-logo">VB</div>
      <h1 class="login-title">VendorBridge</h1>
      <p class="login-subtitle">Procurement & Vendor Management ERP</p>
    </div>

    <% if (error) { %>
      <div class="error-alert">
        <%= error %>
      </div>
    <% } %>

    <form action="/login" method="POST" style="display: flex; flex-direction: column; gap: 1.25rem;">
      <div class="form-group">
        <label for="email">Email Address</label>
        <input type="email" id="email" name="email" class="form-control" placeholder="name@company.com" required>
      </div>

      <div class="form-group" style="margin-bottom: 0.5rem;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <label for="password">Password</label>
          <a href="/forgot-password" style="font-size: 0.8rem; color: var(--color-primary); text-decoration: none; font-weight: 500;">Forgot Password?</a>
        </div>
        <input type="password" id="password" name="password" class="form-control" placeholder="••••••••" required>
      </div>

      <button type="submit" class="btn btn-primary" style="width: 100%; height: 44px; font-weight: 600;">
        <i data-lucide="log-in" style="width: 18px; height: 18px;"></i>
        <span>Sign In</span>
      </button>
    </form>

    <div style="text-align: center; font-size: 0.85rem; color: var(--text-muted); margin: 0.5rem 0;">
      Don't have an account? <a href="/signup" style="color: var(--color-primary); text-decoration: none; font-weight: 600;">Sign Up</a>
    </div>

    <!-- Hackathon Quick-Login Credentials (very helpful for testing) -->
    <div style="border-top: 1px solid var(--border-light); padding-top: 1rem; margin-top: 0.5rem;">
      <p style="font-size: 0.8rem; font-weight: 600; color: var(--color-primary); margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em;">
        Hackathon Demo Accounts:
      </p>
      <div style="display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.75rem; color: var(--text-muted);">
        <div style="cursor: pointer; padding: 0.35rem 0.5rem; background: rgba(255,255,255,0.02); border-radius: var(--radius-sm); border: 1px solid var(--border-light);" onclick="fillCreds('officer@vendorbridge.com', 'officer123')">
          <strong style="color: var(--text-main);">Procurement Officer:</strong> officer@vendorbridge.com <span style="float:right; color:var(--text-subtle)">PW: officer123</span>
        </div>
        <div style="cursor: pointer; padding: 0.35rem 0.5rem; background: rgba(255,255,255,0.02); border-radius: var(--radius-sm); border: 1px solid var(--border-light);" onclick="fillCreds('vendor@vendorbridge.com', 'vendor123')">
          <strong style="color: var(--text-main);">Assigned Vendor:</strong> vendor@vendorbridge.com <span style="float:right; color:var(--text-subtle)">PW: vendor123</span>
        </div>
        <div style="cursor: pointer; padding: 0.35rem 0.5rem; background: rgba(255,255,255,0.02); border-radius: var(--radius-sm); border: 1px solid var(--border-light);" onclick="fillCreds('manager@vendorbridge.com', 'manager123')">
          <strong style="color: var(--text-main);">Approver / Manager:</strong> manager@vendorbridge.com <span style="float:right; color:var(--text-subtle)">PW: manager123</span>
        </div>
        <div style="cursor: pointer; padding: 0.35rem 0.5rem; background: rgba(255,255,255,0.02); border-radius: var(--radius-sm); border: 1px solid var(--border-light);" onclick="fillCreds('admin@vendorbridge.com', 'admin123')">
          <strong style="color: var(--text-main);">System Admin:</strong> admin@vendorbridge.com <span style="float:right; color:var(--text-subtle)">PW: admin123</span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function fillCreds(email, password) {
    document.getElementById('email').value = email;
    document.getElementById('password').value = password;
  }
</script>

<%- include('partials/footer') %>
