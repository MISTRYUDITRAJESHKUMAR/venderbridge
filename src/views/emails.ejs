<%- include('partials/head', { title: 'Email Outbox' }) %>

<div class="app-container">
  <%- include('partials/sidebar') %>

  <main class="main-wrapper">
    <!-- Top Header -->
    <div class="top-bar">
      <div class="page-title">
        <h1>Simulated Email Outbox</h1>
        <p>Monitor system-generated transactional notifications dispatched to vendors and officers.</p>
      </div>
    </div>

    <!-- Email List Panel -->
    <div class="panel">
      <div class="panel-header">
        <h3 class="panel-title">Mail Outbox Logs</h3>
        <span style="font-size: 0.8rem; color: var(--text-muted);">Simulated SMTP Transmissions</span>
      </div>

      <% if (emails.length === 0) { %>
        <div style="text-align: center; padding: 4rem; color: var(--text-muted);">
          <div style="margin-bottom: 1rem;"><i data-lucide="mail-warning" style="width: 48px; height: 48px; color: var(--text-subtle);"></i></div>
          <h3>No Emails Sent</h3>
          <p style="font-size: 0.9rem; margin-top: 0.25rem;">The system has not dispatched any automated email notifications yet.</p>
        </div>
      <% } else { %>
        <div style="display: flex; flex-direction: column; gap: 1.25rem; margin-top: 1rem;">
          <% emails.forEach(email => { %>
            <div style="border: 1px solid var(--border-light); border-radius: var(--radius-md); background: rgba(255,255,255,0.015); overflow: hidden;">
              
              <!-- Mail Header -->
              <div style="background: rgba(255,255,255,0.02); padding: 1rem 1.25rem; border-bottom: 1px solid var(--border-light); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
                <div>
                  <div style="font-weight: 600; font-size: 1rem; color: var(--text-main);"><%= email.subject %></div>
                  <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.15rem;">
                    To: <span style="color: var(--color-info);"><%= email.recipient_email %></span>
                  </div>
                </div>
                <div style="font-size: 0.75rem; color: var(--text-muted);">
                  Sent: <%= new Date(email.sent_at).toLocaleString() %>
                </div>
              </div>

              <!-- Mail Body -->
              <div style="padding: 1.25rem; font-family: monospace; font-size: 0.85rem; color: var(--text-main); white-space: pre-line; line-height: 1.5; background: rgba(0,0,0,0.2);">
                <%= email.body %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </main>
</div>

<%- include('partials/footer') %>
