<%- include('partials/head', { title: 'Compare Quotations' }) %>

<div class="app-container">
  <%- include('partials/sidebar') %>

  <main class="main-wrapper">
    <div class="top-bar">
      <div class="page-title">
        <h1>Quotation Comparison</h1>
        <p>Compare pricing, timeline, and quality ratings side-by-side to select the optimal supplier.</p>
      </div>
      <div>
        <a href="/rfqs" class="btn btn-secondary">
          <i data-lucide="arrow-left"></i>
          <span>Back to RFQs</span>
        </a>
      </div>
    </div>

    <!-- RFQ Info -->
    <div class="panel" style="background: rgba(99, 102, 241, 0.03); border-color: rgba(99, 102, 241, 0.15);">
      <h3 style="font-size: 1.1rem; font-family: 'Outfit'; color: var(--color-primary);"><%= rfq.title %></h3>
      <p style="font-size: 0.9rem; margin-top: 0.25rem;"><%= rfq.description %></p>
      <div style="display: flex; gap: 1rem; margin-top: 0.75rem; font-size: 0.8rem; color: var(--text-muted);">
        <span>RFQ ID: <code style="color:var(--text-main)"><%= rfq.id %></code></span>
        <span>&bull;</span>
        <span>Items: <strong><%= rfq.items.length %></strong></span>
        <span>&bull;</span>
        <span>Total Quotes Received: <strong><%= quotes.length %></strong></span>
      </div>
    </div>

    <!-- Comparison Cards Grid -->
    <div class="comparison-grid">
      <% quotes.forEach(quote => { %>
        <% 
          let cardClass = '';
          if (quote.id === lowestQuoteId) cardClass = 'highlight-lowest';
          else if (quote.id === fastestQuoteId) cardClass = 'highlight-fastest';
        %>
        <div class="comparison-card <%= cardClass %>">
          
          <!-- Vendor Bio -->
          <div>
            <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 0.5rem; margin-bottom: 0.25rem;">
              <h4 style="font-size: 1.1rem; font-family: 'Outfit'; color: var(--text-main);"><%= quote.vendor_name %></h4>
              <span class="badge <%= quote.status.toLowerCase() %>" style="margin-top: 0.15rem;"><%= quote.status %></span>
            </div>
            
            <div style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.5rem;">
              <div style="display: flex; align-items: center; gap: 0.15rem;">
                <i data-lucide="star" style="width: 12px; height: 12px; fill: var(--color-warning); color: var(--color-warning);"></i>
                <span style="font-weight:600;"><%= quote.vendor_rating.toFixed(1) %></span>
              </div>
              <span>&bull;</span>
              <span>GST: <%= quote.vendor_gst %></span>
            </div>
          </div>

          <!-- Total Cost -->
          <div style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-light); border-radius: var(--radius-md); padding: 0.75rem 1rem;">
            <span style="font-size: 0.75rem; text-transform: uppercase; color: var(--text-muted); font-weight:600;">Total Bid Value</span>
            <div class="comparison-price">₹<%= quote.totalValue.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></div>
            
            <div style="display: flex; justify-content: space-between; font-size: 0.85rem; color: var(--text-muted); margin-top: 0.5rem; border-top: 1px solid var(--border-light); padding-top: 0.5rem;">
              <span>Delivery Timeline:</span>
              <strong style="color: var(--text-main);"><%= quote.delivery_timeline_days %> Days</strong>
            </div>
          </div>

          <!-- Items Breakdown -->
          <div>
            <h5 style="font-size: 0.8rem; text-transform: uppercase; color: var(--text-muted); font-weight:600; margin-bottom: 0.5rem; border-bottom: 1px solid var(--border-light); padding-bottom: 0.25rem;">Item Quotes</h5>
            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
              <% rfq.items.forEach(rfqItem => { %>
                <% 
                  const quoteItem = quote.items.find(qi => qi.itemId === rfqItem.id);
                %>
                <div style="display: flex; justify-content: space-between; align-items: center; font-size: 0.85rem;">
                  <span style="text-overflow: ellipsis; overflow: hidden; white-space: nowrap; max-width: 140px;" title="<%= rfqItem.name %>"><%= rfqItem.name %></span>
                  <div style="text-align: right;">
                    <div style="font-weight: 600; color: var(--text-main); font-family: monospace;">₹<%= quoteItem ? quoteItem.pricePerUnit.toFixed(2) : '0.00' %> / <%= rfqItem.unit %></div>
                    <div style="font-size: 0.7rem; color: var(--text-muted);">Total: ₹<%= quoteItem ? quoteItem.totalPrice.toFixed(2) : '0.00' %></div>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>

          <!-- Notes -->
          <% if (quote.notes && quote.notes.trim() !== '') { %>
            <div style="font-size: 0.8rem; color: var(--text-muted); background: rgba(255,255,255,0.01); border: 1px dashed var(--border-light); padding: 0.5rem 0.75rem; border-radius: var(--radius-sm);">
              <strong>Remarks:</strong> <%= quote.notes %>
            </div>
          <% } %>

          <!-- Workflow Action Trigger -->
          <% if (rfq.status === 'ACTIVE' && quote.status === 'SUBMITTED' && user.role === 'PROCUREMENT_OFFICER') { %>
            <div style="margin-top: auto; padding-top: 1rem;" class="no-print">
              <form action="/approvals/request" method="POST">
                <input type="hidden" name="quoteId" value="<%= quote.id %>">
                <input type="hidden" name="rfqId" value="<%= rfq.id %>">
                <button type="submit" class="btn btn-primary" style="width: 100%;">
                  <i data-lucide="shield-alert"></i>
                  <span>Submit for Approval</span>
                </button>
              </form>
            </div>
          <% } else if (quote.status === 'UNDER_REVIEW') { %>
            <div style="margin-top: auto; padding-top: 1rem; text-align: center; color: var(--color-warning); font-size: 0.85rem; font-weight: 600;" class="no-print">
              <i data-lucide="clock" style="width: 16px; height: 16px; vertical-align: middle; margin-right: 0.25rem;"></i>
              <span>Sent for Approval</span>
            </div>
          <% } else if (quote.status === 'APPROVED') { %>
            <div style="margin-top: auto; padding-top: 1rem; text-align: center; color: var(--color-success); font-size: 0.85rem; font-weight: 600;" class="no-print">
              <i data-lucide="check-circle" style="width: 16px; height: 16px; vertical-align: middle; margin-right: 0.25rem;"></i>
              <span>Approved Quote</span>
            </div>
          <% } else if (quote.status === 'REJECTED') { %>
            <div style="margin-top: auto; padding-top: 1rem; text-align: center; color: var(--color-danger); font-size: 0.85rem;" class="no-print">
              <span>Rejected</span>
              <% if (quote.approval_remarks) { %>
                <div style="font-size:0.7rem; color:var(--text-muted); margin-top:0.25rem;">"<%= quote.approval_remarks %>"</div>
              <% } %>
            </div>
          <% } %>

        </div>
      <% }) %>
    </div>
  </main>
</div>

<%- include('partials/footer') %>
