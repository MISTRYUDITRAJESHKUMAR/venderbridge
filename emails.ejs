@media print {
  /* Hide all non-printable UI components */
  .sidebar,
  .top-bar,
  .btn,
  button,
  .no-print,
  .nav-menu,
  .logout-btn,
  .user-profile {
    display: none !important;
  }

  /* Reset layout structure for clean standard paper margins */
  html, body {
    background: #ffffff !important;
    color: #000000 !important;
    font-family: 'Inter', Arial, sans-serif;
    font-size: 11pt;
    line-height: 1.4;
    margin: 0;
    padding: 0;
    width: 100%;
  }

  .app-container {
    display: block !important;
    grid-template-columns: none !important;
    min-height: 0 !important;
  }

  .main-wrapper {
    padding: 0 !important;
    margin: 0 !important;
    overflow: visible !important;
    width: 100% !important;
  }

  /* Invoice/PO Document Frame */
  .document-print {
    border: none !important;
    box-shadow: none !important;
    padding: 0 !important;
    margin: 0 !important;
    background: transparent !important;
    color: #000000 !important;
    width: 100% !important;
  }

  /* Heading & Typography Adjustments */
  h1, h2, h3, h4, h5, h6 {
    color: #000000 !important;
    font-family: 'Outfit', Arial, sans-serif;
  }

  /* Data tables for print */
  table {
    width: 100% !important;
    border-collapse: collapse !important;
    margin-top: 15px !important;
    margin-bottom: 15px !important;
    page-break-inside: auto;
  }

  tr {
    page-break-inside: avoid;
    page-break-after: auto;
  }

  thead {
    display: table-header-group;
  }

  th {
    border-bottom: 2px solid #000000 !important;
    color: #000000 !important;
    font-weight: 750 !important;
    text-transform: uppercase !important;
    font-size: 9pt !important;
    padding: 6px !important;
  }

  td {
    border-bottom: 1px solid #dddddd !important;
    color: #000000 !important;
    padding: 6px !important;
    font-size: 9.5pt !important;
  }

  /* Totals section alignment */
  .totals-box {
    margin-top: 20px !important;
    float: right !important;
    width: 300px !important;
    border-top: 2px solid #000000 !important;
    padding-top: 8px !important;
    page-break-inside: avoid;
  }

  .totals-row {
    display: flex !important;
    justify-content: space-between !important;
    font-size: 10pt !important;
    padding: 4px 0 !important;
  }

  .totals-row.grand-total {
    border-top: 1px solid #000000 !important;
    font-weight: bold !important;
    font-size: 11pt !important;
  }

  /* Clear float for following sections */
  .clearfix::after {
    content: "";
    clear: both;
    display: table;
  }

  /* Page break helpers */
  .page-break {
    page-break-before: always;
  }
  
  .badge {
    border: 1px solid #000000 !important;
    background: transparent !important;
    color: #000000 !important;
    padding: 2px 6px !important;
    font-size: 8pt !important;
  }
}
