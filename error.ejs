@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap');

:root {
  /* HSL theme tokens - modern dark slate theme with indigo accent */
  --bg-base: #080c14;
  --bg-surface: #0f172a;
  --bg-card: #1e293b;
  --bg-input: #0f172a;
  
  --text-main: #f8fafc;
  --text-muted: #94a3b8;
  --text-subtle: #475569;
  
  --color-primary: #6366f1;
  --color-primary-hover: #4f46e5;
  --color-primary-rgb: 99, 102, 241;
  
  --color-success: #10b981;
  --color-success-bg: rgba(16, 185, 129, 0.1);
  --color-warning: #f59e0b;
  --color-warning-bg: rgba(245, 158, 11, 0.1);
  --color-danger: #ef4444;
  --color-danger-bg: rgba(239, 68, 68, 0.1);
  --color-info: #0ea5e9;
  --color-info-bg: rgba(14, 165, 233, 0.1);

  /* Borders & Shadows */
  --border-light: rgba(255, 255, 255, 0.06);
  --border-focus: rgba(99, 102, 241, 0.5);
  --radius-sm: 6px;
  --radius-md: 12px;
  --radius-lg: 18px;
  
  --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.2);
  --shadow-md: 0 10px 25px -5px rgba(0, 0, 0, 0.3), 0 8px 10px -6px rgba(0, 0, 0, 0.3);
  --shadow-lg: 0 20px 50px -12px rgba(0, 0, 0, 0.5);
  --glass-bg: rgba(15, 23, 42, 0.65);
  --glass-blur: blur(12px);

  /* Animation durations */
  --anim-fast: 0.15s;
  --anim-normal: 0.3s;
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  font-family: 'Inter', sans-serif;
  background-color: var(--bg-base);
  color: var(--text-main);
  line-height: 1.5;
  overflow-x: hidden;
}

h1, h2, h3, h4, h5, h6 {
  font-family: 'Outfit', sans-serif;
  font-weight: 600;
  letter-spacing: -0.02em;
}

/* Custom Scrollbar */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}
::-webkit-scrollbar-track {
  background: var(--bg-base);
}
::-webkit-scrollbar-thumb {
  background: var(--text-subtle);
  border-radius: var(--radius-sm);
}
::-webkit-scrollbar-thumb:hover {
  background: var(--text-muted);
}

/* App Layout Grid */
.app-container {
  display: grid;
  grid-template-columns: 260px 1fr;
  min-height: 100vh;
}

/* Sidebar Styling */
.sidebar {
  background: var(--bg-surface);
  border-right: 1px solid var(--border-light);
  display: flex;
  flex-direction: column;
  padding: 1.5rem 1rem;
  height: 100vh;
  position: sticky;
  top: 0;
}

.brand {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.5rem 1rem 1.5rem 1rem;
  border-bottom: 1px solid var(--border-light);
  margin-bottom: 1.5rem;
}

.brand-logo {
  background: linear-gradient(135deg, var(--color-primary), #a78bfa);
  width: 32px;
  height: 32px;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-family: 'Outfit', sans-serif;
  color: white;
}

.brand-name {
  font-size: 1.25rem;
  font-weight: 700;
  background: linear-gradient(to right, #ffffff, #a78bfa);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.user-profile {
  background: var(--border-light);
  padding: 0.75rem 1rem;
  border-radius: var(--radius-md);
  margin-bottom: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.user-name {
  font-weight: 500;
  font-size: 0.9rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.user-role {
  font-size: 0.75rem;
  color: var(--color-primary);
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.nav-menu {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
  flex-grow: 1;
}

.nav-item a {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem 1rem;
  color: var(--text-muted);
  text-decoration: none;
  border-radius: var(--radius-md);
  font-size: 0.95rem;
  font-weight: 500;
  transition: var(--transition-smooth);
}

.nav-item a:hover {
  background: rgba(255, 255, 255, 0.03);
  color: var(--text-main);
  padding-left: 1.25rem;
}

.nav-item.active a {
  background: rgba(var(--color-primary-rgb), 0.12);
  color: var(--color-primary);
  font-weight: 600;
}

.nav-item a svg {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
}

.logout-btn {
  border-top: 1px solid var(--border-light);
  padding-top: 1rem;
}

/* Main Content Area */
.main-wrapper {
  padding: 2rem;
  display: flex;
  flex-direction: column;
  gap: 2rem;
  overflow-y: auto;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1rem;
}

.page-title h1 {
  font-size: 1.85rem;
  margin-bottom: 0.25rem;
}

.page-title p {
  color: var(--text-muted);
  font-size: 0.95rem;
}

/* Cards & Metric Blocks */
.metrics-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1.5rem;
}

.metric-card {
  background: var(--bg-surface);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-lg);
  padding: 1.5rem;
  display: flex;
  align-items: center;
  gap: 1.25rem;
  box-shadow: var(--shadow-sm);
  transition: var(--transition-smooth);
  position: relative;
  overflow: hidden;
}

.metric-card:hover {
  transform: translateY(-4px);
  border-color: rgba(var(--color-primary-rgb), 0.2);
  box-shadow: var(--shadow-md);
}

.metric-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 4px;
  height: 100%;
  background: var(--color-primary);
  opacity: 0;
  transition: var(--transition-smooth);
}

.metric-card:hover::before {
  opacity: 1;
}

.metric-icon {
  width: 48px;
  height: 48px;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.25rem;
}

.metric-icon.primary { background: rgba(99, 102, 241, 0.1); color: var(--color-primary); }
.metric-icon.success { background: rgba(16, 185, 129, 0.1); color: var(--color-success); }
.metric-icon.warning { background: rgba(245, 158, 11, 0.1); color: var(--color-warning); }
.metric-icon.danger { background: rgba(239, 68, 68, 0.1); color: var(--color-danger); }
.metric-icon.info { background: rgba(14, 165, 233, 0.1); color: var(--color-info); }

.metric-info {
  display: flex;
  flex-direction: column;
}

.metric-value {
  font-size: 1.5rem;
  font-weight: 700;
  font-family: 'Outfit', sans-serif;
}

.metric-label {
  font-size: 0.8rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* Sections & Panels */
.dashboard-grid {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 1.5rem;
}

.panel {
  background: var(--bg-surface);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-lg);
  padding: 1.5rem;
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid var(--border-light);
  padding-bottom: 0.75rem;
}

.panel-title {
  font-size: 1.1rem;
  color: var(--text-main);
}

/* Tables & Lists */
.table-responsive {
  width: 100%;
  overflow-x: auto;
}

.data-table {
  width: 100%;
  border-collapse: collapse;
  text-align: left;
  font-size: 0.9rem;
}

.data-table th {
  color: var(--text-muted);
  font-weight: 600;
  padding: 0.85rem 1rem;
  border-bottom: 1px solid var(--border-light);
  text-transform: uppercase;
  font-size: 0.75rem;
  letter-spacing: 0.05em;
}

.data-table td {
  padding: 1rem;
  border-bottom: 1px solid var(--border-light);
  color: var(--text-main);
  vertical-align: middle;
}

.data-table tbody tr {
  transition: var(--anim-fast) ease-in-out;
}

.data-table tbody tr:hover {
  background: rgba(255, 255, 255, 0.015);
}

/* Status Badges */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 0.25rem 0.6rem;
  border-radius: 9999px;
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.02em;
}

.badge.active, .badge.approved, .badge.paid { background: var(--color-success-bg); color: var(--color-success); }
.badge.pending, .badge.under_review, .badge.pending_approval { background: var(--color-warning-bg); color: var(--color-warning); }
.badge.closed, .badge.rejected, .badge.blacklisted { background: var(--color-danger-bg); color: var(--color-danger); }
.badge.draft, .badge.submitted, .badge.issued { background: var(--color-info-bg); color: var(--color-info); }

/* Buttons & Interactive Elements */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.6rem 1.2rem;
  border-radius: var(--radius-md);
  font-size: 0.9rem;
  font-weight: 500;
  cursor: pointer;
  border: 1px solid transparent;
  transition: var(--transition-smooth);
  text-decoration: none;
  font-family: 'Inter', sans-serif;
}

.btn-primary {
  background: var(--color-primary);
  color: white;
}

.btn-primary:hover {
  background: var(--color-primary-hover);
  box-shadow: 0 0 15px rgba(var(--color-primary-rgb), 0.4);
}

.btn-secondary {
  background: transparent;
  border-color: var(--border-light);
  color: var(--text-main);
}

.btn-secondary:hover {
  background: var(--border-light);
  color: white;
}

.btn-success {
  background: var(--color-success);
  color: white;
}
.btn-success:hover {
  opacity: 0.9;
  box-shadow: 0 0 15px rgba(16, 185, 129, 0.4);
}

.btn-danger {
  background: var(--color-danger);
  color: white;
}
.btn-danger:hover {
  opacity: 0.9;
}

.btn-sm {
  padding: 0.35rem 0.75rem;
  font-size: 0.8rem;
  border-radius: var(--radius-sm);
}

/* Form Styling */
.form-group {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  margin-bottom: 1.25rem;
}

.form-group label {
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--text-muted);
}

.form-control {
  background: var(--bg-input);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-md);
  padding: 0.75rem 1rem;
  color: var(--text-main);
  font-family: inherit;
  font-size: 0.9rem;
  transition: var(--transition-smooth);
}

.form-control:focus {
  outline: none;
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3px var(--primary-glow);
}

textarea.form-control {
  resize: vertical;
  min-height: 80px;
}

/* Login Page Styling */
.login-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background-color: var(--bg-base);
  padding: 1.5rem;
  background-image: radial-gradient(circle at 10% 20%, rgba(99, 102, 241, 0.05) 0%, transparent 45%);
}

.login-card {
  background: var(--bg-surface);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-lg);
  padding: 2.5rem;
  width: 100%;
  max-width: 440px;
  box-shadow: var(--shadow-lg);
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.login-header {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
}

.login-logo {
  background: linear-gradient(135deg, var(--color-primary), #a78bfa);
  width: 48px;
  height: 48px;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  font-weight: 700;
  color: white;
  margin-bottom: 0.5rem;
}

.login-title {
  font-size: 1.5rem;
  font-weight: 700;
}

.login-subtitle {
  font-size: 0.85rem;
  color: var(--text-muted);
}

.error-alert {
  background: rgba(239, 68, 68, 0.12);
  border: 1px solid var(--color-danger);
  color: var(--color-danger);
  padding: 0.75rem 1rem;
  border-radius: var(--radius-md);
  font-size: 0.85rem;
  font-weight: 500;
}

/* Info Box / Timeline */
.timeline {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  position: relative;
}

.timeline::before {
  content: '';
  position: absolute;
  top: 0.25rem;
  left: 15px;
  width: 2px;
  height: calc(100% - 0.5rem);
  background: var(--border-light);
}

.timeline-item {
  display: flex;
  gap: 1.25rem;
  position: relative;
}

.timeline-marker {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--bg-card);
  border: 2px solid var(--border-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.85rem;
  color: var(--text-muted);
  flex-shrink: 0;
  z-index: 1;
}

.timeline-item.active .timeline-marker {
  border-color: var(--color-primary);
  color: var(--color-primary);
  background: rgba(var(--color-primary-rgb), 0.1);
}

.timeline-content {
  display: flex;
  flex-direction: column;
  padding-top: 0.2rem;
}

.timeline-title {
  font-size: 0.9rem;
  font-weight: 600;
}

.timeline-desc {
  font-size: 0.8rem;
  color: var(--text-muted);
}

.timeline-time {
  font-size: 0.75rem;
  color: var(--text-subtle);
  margin-top: 0.15rem;
}

/* Comparison View Column Styling */
.comparison-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.5rem;
}

.comparison-card {
  background: var(--bg-surface);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-lg);
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  position: relative;
}

.comparison-card.highlight-lowest {
  border-color: var(--color-success);
  box-shadow: 0 0 20px rgba(16, 185, 129, 0.12);
}

.comparison-card.highlight-lowest::after {
  content: 'Lowest Price';
  position: absolute;
  top: 1rem;
  right: 1rem;
  background: var(--color-success-bg);
  color: var(--color-success);
  font-size: 0.7rem;
  font-weight: 700;
  padding: 0.25rem 0.5rem;
  border-radius: var(--radius-sm);
  text-transform: uppercase;
}

.comparison-card.highlight-fastest {
  border-color: var(--color-info);
  box-shadow: 0 0 20px rgba(14, 165, 233, 0.12);
}

.comparison-card.highlight-fastest::after {
  content: 'Fastest Delivery';
  position: absolute;
  top: 1rem;
  right: 1rem;
  background: var(--color-info-bg);
  color: var(--color-info);
  font-size: 0.7rem;
  font-weight: 700;
  padding: 0.25rem 0.5rem;
  border-radius: var(--radius-sm);
  text-transform: uppercase;
}

.comparison-price {
  font-size: 1.75rem;
  font-weight: 700;
  color: var(--text-main);
  font-family: 'Outfit', sans-serif;
  margin: 0.5rem 0;
}

/* Layout Utilities */
.text-right { text-align: right; }
.flex-row { display: flex; align-items: center; gap: 0.5rem; }
.justify-between { justify-content: space-between; }
.align-center { align-items: center; }

/* Modal layout styling */
.modal-backdrop {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(4px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: var(--bg-surface);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-lg);
  padding: 2rem;
  width: 100%;
  max-width: 500px;
  box-shadow: var(--shadow-lg);
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}
